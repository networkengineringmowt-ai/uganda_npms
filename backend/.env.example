# Service
NPMS_APP_NAME=Uganda NPMS Backend
NPMS_ENVIRONMENT=development
NPMS_HOST=127.0.0.1
NPMS_PORT=8000
NPMS_LOG_LEVEL=INFO

# Supabase PostgreSQL connection string. Keep the real value only in .env or a
# Kubernetes Secret; never commit it. Use the transaction pooler URI supplied
# by Project Settings > Database when the cluster cannot use IPv6.
PMS_DATABASE_URL=
PMS_POSTGRES_PREPARE_THRESHOLD=
PMS_POSTGRES_STATEMENT_TIMEOUT_MS=0
PMS_SYNC_BATCH_SIZE=50000
PMS_SYNC_TABLES=
PMS_SYNC_WRITE_MODE=upsert
PMS_SYNC_REPLACE_EXISTING=false
PMS_SYNC_ROW_OFFSET=0
PMS_SYNC_ROW_LIMIT=
PMS_AUTO_MIGRATE=false
PMS_POSTGRES_SCHEMA_PATH=../supabase/migrations/20260720103000_npms_backend.sql
PMS_CORS_ORIGINS=http://localhost:5173,https://networkengineringmowt-ai.github.io

# Storage and model artifacts (absolute paths are recommended in production)
PMS_DB_PATH=../data/npms_backend.db
PMS_MODEL_PATH=./artifacts/pavement_model.joblib
PMS_SCHEMA_PATH=./sql/pms_backend_schema.sql
PMS_FUNCTIONS_PATH=./sql/pms_functions.sql

# Pavement engineering variables
PMS_REPORTING_YEAR=2026
PMS_IRI_GOOD_UPPER=3.5
PMS_IRI_FAIR_UPPER=6.5
PMS_IRI_POOR_UPPER=9.0
PMS_ANNUAL_IRI_GROWTH=0.18
PMS_GRAVEL_IRI_GROWTH=0.32
PMS_CONFIDENCE_DECAY=0.08

# Machine learning
PMS_RANDOM_SEED=42
PMS_MIN_TRAINING_ROWS=20
PMS_MAX_API_ROWS=2000

# Set a long random value before exposing administrative endpoints
PMS_ADMIN_KEY=

# Full repository ingestion engine
NPMS_REPOSITORY_ROOT=../..
NPMS_DEPLOY_ROOT=..
